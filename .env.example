# ============================================================
# Environment Variables - Enhanced RAG Setup
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Sarvam AI (for multilingual support)
SARVAM_API_KEY=your_sarvam_api_key

# Gemini (for diagram generation and PDF vision)
GEMINI_API_KEY=your_gemini_api_key

# HuggingFace (for BGE reranker - OPTIONAL)
# If not set, will use fallback text-overlap-based reranking
# Get free key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_key

# ThingsBoard (for IoT integration)
THINGSBOARD_URL=https://your-thingsboard-instance.com
THINGSBOARD_TOKEN=your_device_token
ADMIN_API_KEY=your_admin_api_key

# ============================================================
# Optional Features
# ============================================================

# Enable enhanced RAG features
# Set to 'true' to enable hybrid search, knowledge graph boosting
NEXT_PUBLIC_USE_ENHANCED_RAG=false

# RAG configuration
RAG_HYDE_ENABLED=true
RAG_USE_MMR=true
RAG_USE_HYBRID_SEARCH=false
RAG_USE_GRAPH_BOOST=false
